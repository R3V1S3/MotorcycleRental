<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="MotorcycleRentalDB"
			 connectionString="Host=localhost;Port=5432;Database=MotorcycleRental;Username=postgres;Password=YOUR_PASSWORD"
			 providerName="Npgsql" />
	</connectionStrings>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
</configuration>